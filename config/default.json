{
  "host": "localhost",
  "port": 3030,
  "public": "../public/build",
  "paginate": {
    "default": 10,
    "max": 25
  },
  "authentication": {
    "secret": "AUTH_SECRET_PLACEHOLDER",
    "entity": "user",
    "service": "user",
    "authStrategies": ["local", "jwt"],
    "local": {
      "usernameField": "email",
      "passwordField": "password"
    },
    "jwtOptions": {
      "header": {
        "type": "aceess"
      },
      "data": {
        "aceess_token": ""
      },
      "verify": {
        "ops": 6
      }
    }
  },
  "mongodb": "${mongodbdata}",
  "domain": "https://YOUR_DOMAIN.com",
  "uploadPath": "/builduploads/",
  "uploadShowPath": "/uploads/"
}
